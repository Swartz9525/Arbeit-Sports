{
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://arbeit-sports-tutt.vercel.app/api/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "https://arbeit-sports-tutt.vercel.app/uploads/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
