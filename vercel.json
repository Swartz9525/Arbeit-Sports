{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://arbeit-sports-tutt.vercel.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://arbeit-sports-tutt.vercel.app/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
